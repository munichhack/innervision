<?xml version="1.0" encoding="utf-8"?>
<!-- FloorPlanView fills the screen. ARCore needs a real, continuously rendering
     GL surface to stay in TRACKING; it is kept off-screen (same size, negative
     margins) so nothing visible covers the map. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.blindvision.arpose.nav.FloorPlanView
        android:id="@+id/floor_plan"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <android.opengl.GLSurfaceView
        android:id="@+id/gl_surface"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-180dp"
        android:layout_marginEnd="-132dp" />

    <TextView
        android:id="@+id/pose_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="#CC101418"
        android:padding="12dp"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:text="" />
</FrameLayout>
