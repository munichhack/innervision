<?xml version="1.0" encoding="utf-8"?>
<!-- The FloorPlanView fills the screen. ARCore needs a real, continuously
     rendering GL surface to stay in TRACKING, but a full-screen SurfaceView is
     composited above the window on this device and hides the UI. So the
     GLSurfaceView is kept as a small preview box in the top-right corner (large
     enough for ARCore to run reliably). This box is exactly where the live
     camera feed will be drawn as the planned next step. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.blindvision.arpose.nav.FloorPlanView
        android:id="@+id/floor_plan"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <android.opengl.GLSurfaceView
        android:id="@+id/gl_surface"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="64dp"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC101418"
        android:padding="12dp"
        android:textColor="#FF80FF80"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:text="Initializing…" />

    <TextView
        android:id="@+id/pose_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="#CC101418"
        android:padding="12dp"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:text="" />
</FrameLayout>
